import java.util.Scanner;


class Solution {
    public boolean isPalindrome(int x) {
        if(x<0){
            return false;
        }
        int original=x;
     
       int num = 0;
       
       while(x>0){
          int imp = x%10;
        x/=10;
        
        num*=10;
        num+=imp;
        }
      return original==num;

    }

}

    
   
